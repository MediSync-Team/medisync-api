NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=postgresql://user:password@host:5432/medisync

# Auth
JWT_SECRET=replace-with-very-long-random-secret

# Public URLs
FRONTEND_URL=https://medisync-web.medisync.workers.dev/
FRONTEND_URLS=https://medisync-web.medisync.workers.dev/
BACKEND_URL=https://medisync-api-production.up.railway.app/api

# Storage
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Mercado Pago
# Platform token: fallback for professionals without a linked account + Pro billing.
MP_ACCESS_TOKEN=replace-with-production-access-token
MP_WEBHOOK_SECRET=replace-with-webhook-secret
# OAuth (Marketplace) — per-professional account linking. App credentials from
# https://www.mercadopago.com.ar/developers. Redirect URI must match the app config.
MP_CLIENT_ID=replace-with-mp-app-client-id
MP_CLIENT_SECRET=replace-with-mp-app-client-secret
MP_OAUTH_REDIRECT_URI=https://api.example.com/api/mercadopago/oauth/callback
MP_MARKETPLACE_FEE_PERCENT=0

# Sprint 1 - Operacion
CANCELLATION_WINDOW_HOURS=24

# Notificaciones (Produccion)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=MediSync <no-reply@yourdomain.com>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook opcional para observabilidad interna
NOTIFICATIONS_WEBHOOK_URL=

# Video TURN relay (Cloudflare Realtime TURN) — required for cross-network video calls.
# Without these the app falls back to STUN-only (same-network calls only).
CLOUDFLARE_TURN_TOKEN_ID=replace-with-cloudflare-turn-token-id
CLOUDFLARE_TURN_API_TOKEN=replace-with-cloudflare-turn-api-token
TURN_TTL_SECONDS=3600

# Google Calendar (optional)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://api.example.com/api/auth/google/callback
