NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=postgresql://user:password@host:5432/medisync

# Auth
JWT_SECRET=replace-with-very-long-random-secret

# Public URLs
FRONTEND_URL=https://app.example.com
FRONTEND_URLS=https://app.example.com,https://www.app.example.com
BACKEND_URL=https://api.example.com

# Storage
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Mercado Pago
MP_ACCESS_TOKEN=replace-with-production-access-token
MP_WEBHOOK_SECRET=replace-with-webhook-secret

# Sprint 1 - Operacion
CANCELLATION_WINDOW_HOURS=24

# Notificaciones (Produccion)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=MediSync <no-reply@yourdomain.com>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook opcional para observabilidad interna
NOTIFICATIONS_WEBHOOK_URL=

# Google Calendar (optional)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://api.example.com/api/auth/google/callback
