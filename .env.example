# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medisync

# Auth
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
# Encrypts secrets at rest (Google OAuth tokens). 64 hex chars (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required to connect/use Google Calendar sync.
TOKEN_ENCRYPTION_KEY=change-this-to-64-hex-chars

# Server
PORT=4000
NODE_ENV=development

# URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
# REQUIRED in production: the MercadoPago webhook URL is built from this. Never
# falls back to the request Host header in production (SSRF protection).
BACKEND_URL=http://localhost:4000

# Cloud Storage (Cloudinary) — durable storage for turno files (clinical + in-call chat).
# Without it, uploads fall back to local ./uploads (ok for dev; ephemeral on Railway).
# Free account at https://cloudinary.com → copy the "API Environment variable".
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Mercado Pago
MP_ACCESS_TOKEN=your-mercadopago-access-token
MP_WEBHOOK_SECRET=your-webhook-secret

# Sprint 1 - Operacion
CANCELLATION_WINDOW_HOURS=24

# Notificaciones (Produccion)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=MediSync <noreply@medisync.website>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook opcional para observabilidad interna
NOTIFICATIONS_WEBHOOK_URL=

# Video (LiveKit SFU) — required for in-app video consultations.
# Free tier: create a project at https://cloud.livekit.io to get url/key/secret.
# Self-host alternative: run `livekit-server --dev` and use its url/key/secret.
# If unset, GET /turnos/:id/video-token returns 503 VIDEO_NOT_CONFIGURED.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google Calendar (opcional)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Geocoding de direcciones (búsqueda por distancia). Default: Nominatim/OSM (gratis).
# Para volumen real usar Google: GEOCODER=google + GOOGLE_MAPS_API_KEY.
GEOCODER=nominatim
GEOCODER_COUNTRY=ar
NOMINATIM_USER_AGENT=MediSync/1.0 (+https://medisync.app)
GOOGLE_MAPS_API_KEY=
