// MediSync - Prisma Schema
// Backend: medisync-api

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Rol {
  PROFESIONAL
  PACIENTE
  ADMIN
}

enum Modalidad {
  PRESENCIAL
  VIRTUAL
  AMBOS
}

enum EstadoTurno {
  RESERVADO
  CONFIRMADO
  COMPLETADO
  CANCELADO
  AUSENTE
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  REEMBOLSADO
}

enum EstadoListaEspera {
  ACTIVA
  NOTIFICADA
  RESUELTA
  CANCELADA
}

enum TipoArchivo {
  EVOLUCION
  LABORATORIO
  IMAGEN
  OTRO
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  NO_ESPECIFICADO
}

enum NivelRiesgoPreconsulta {
  BAJO
  MEDIO
  ALTO
  URGENTE
}

// ==================== MODELOS ====================

model Usuario {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  rol             Rol      @default(PACIENTE)
  googleToken     String?  @map("google_token")
  mpAccessToken   String?  @map("mp_access_token")
  mpRefreshToken  String?  @map("mp_refresh_token")
  mpVendedorId    String?  @map("mp_vendedor_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  profesional     Profesional?
  paciente        Paciente?

  @@map("usuario")
}

model Especialidad {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  icono       String?
  createdAt   DateTime @default(now()) @map("created_at")

  profesionales Profesional[]

  @@map("especialidad")
}

model Profesional {
  id              String   @id @default(uuid())
  usuarioId       String   @unique @map("usuario_id")
  nombre          String
  apellido        String
  telefono        String
  genero          Genero   @default(NO_ESPECIFICADO)
  matricula       String?  @map("matricula")
  precioConsulta  Decimal  @default(0) @map("precio_consulta") @db.Decimal(10, 2)
  bio             String?
  lugarAtencion   String?  @map("lugar_atencion")
  fotoUrl         String?  @map("foto_url")
  activo          Boolean  @default(true)
  notifEmail      Boolean  @default(true) @map("notif_email")
  notifWhatsapp   Boolean  @default(false) @map("notif_whatsapp")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  usuario         Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  especialidad    Especialidad @relation(fields: [especialidadId], references: [id])
  especialidadId String       @map("especialidad_id")

  disponibilidades Disponibilidad[]
  turnos           Turno[]
  listaEspera      ListaEspera[]
  resenas          Resena[]
  bloqueos         BloqueoDisponibilidad[]

  @@map("profesional")
}

model Disponibilidad {
  id              String    @id @default(uuid())
  profesionalId   String    @map("professional_id")
  diaSemana       Int       @map("dia_semana")
  horaInicio      String    @map("hora_inicio")
  horaFin         String    @map("hora_fin")
  modalidad       Modalidad @default(PRESENCIAL)
  lugarAtencion   String?   @map("lugar_atencion")
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")

  profesional     Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)

  @@index([profesionalId])
  @@map("disponibilidad")
}

model Paciente {
  id                   String    @id @default(uuid())
  usuarioId            String    @unique @map("usuario_id")
  nombre               String
  apellido             String
  email                String
  telefono             String?
  genero               Genero    @default(NO_ESPECIFICADO)
  fechaNacimiento      DateTime? @map("fecha_nacimiento")
  dni                  String?
  obraSocial           String?   @map("obra_social")
  fotoUrl              String?   @map("foto_url")
  antecedentesPersonales String?  @map("antecedentes_personales")
  antecedentesFamiliares String?  @map("antecedentes_familiares")
  alergias             String?
  medicacionActual     String?   @map("medicacion_actual")
  habitos              String?
  diagnosticosPrevios  String?   @map("diagnosticos_previos")
  notasClinicasGenerales String? @map("notas_clinicas_generales")
  aceptaRecordatorios  Boolean   @default(true) @map("acepta_recordatorios")
  notifEmail           Boolean   @default(true) @map("notif_email")
  notifWhatsapp        Boolean   @default(false) @map("notif_whatsapp")
  notifRecordatorio24h Boolean   @default(true) @map("notif_recordatorio_24h")
  notifRecordatorio2h  Boolean   @default(false) @map("notif_recordatorio_2h")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  turnos    Turno[]
  listaEspera ListaEspera[]
  resenas   Resena[]

  @@map("paciente")
}

model Turno {
  id                  String      @id @default(uuid())
  profesionalId       String      @map("profesional_id")
  pacienteId          String?     @map("paciente_id")
  fechaHora           DateTime    @map("fecha_hora")
  duracionMin         Int         @default(30) @map("duracion_min")
  modalidad           Modalidad
  estado              EstadoTurno @default(RESERVADO)
  preconsultaMotivo   String?     @map("preconsulta_motivo")
  preconsultaSintomas String?     @map("preconsulta_sintomas")
  preconsultaEscalaDolor Int?     @map("preconsulta_escala_dolor")
  preconsultaEscalaAnsiedad Int?  @map("preconsulta_escala_ansiedad")
  preconsultaInicioSintomas String? @map("preconsulta_inicio_sintomas")
  preconsultaTemperatura Decimal? @map("preconsulta_temperatura") @db.Decimal(4, 1)
  preconsultaNotasPaciente String? @map("preconsulta_notas_paciente")
  preconsultaRiesgo   NivelRiesgoPreconsulta? @map("preconsulta_riesgo")
  preconsultaFlags    Json?       @map("preconsulta_flags")
  preconsultaResumen  String?     @map("preconsulta_resumen")
  preconsultaCompletadaAt DateTime? @map("preconsulta_completada_at")
  linkVideollamada    String?     @map("link_videollamada")
  notasCancelacion    String?     @map("notas_cancelacion")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  profesional  Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)
  paciente     Paciente?   @relation(fields: [pacienteId], references: [id], onDelete: SetNull)

  evolucion    Evolucion?
  recetaIndicacion RecetaIndicacion?
  archivos     Archivo[]
  pago         Pago?
  resena       Resena?

  @@unique([profesionalId, fechaHora])
  @@index([profesionalId, fechaHora])
  @@index([pacienteId])
  @@index([estado, fechaHora])
  @@map("turno")
}

model RecetaIndicacion {
  id                 String   @id @default(uuid())
  turnoId            String   @unique @map("turno_id")
  diagnostico        String
  planTratamiento    String?  @map("plan_tratamiento")
  medicamentos       String?
  indicaciones       String
  estudiosSolicitados String? @map("estudios_solicitados")
  proximoControl     String?  @map("proximo_control")
  advertencias       String?
  observaciones      String?
  emitidaAt          DateTime @default(now()) @map("emitida_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  turno Turno @relation(fields: [turnoId], references: [id], onDelete: Cascade)

  @@map("receta_indicacion")
}

model Evolucion {
  id        String   @id @default(uuid())
  turnoId   String   @unique @map("turno_id")
  contenido String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  turno Turno @relation(fields: [turnoId], references: [id], onDelete: Cascade)

  @@map("evolucion")
}

model Archivo {
  id              String      @id @default(uuid())
  turnoId         String      @map("turno_id")
  tipo            TipoArchivo @default(OTRO)
  url             String
  nombreOriginal  String      @map("nombre_original")
  tamanoBytes     Int         @map("tamano_bytes")
  mimeType        String      @map("mime_type")
  createdAt       DateTime    @default(now()) @map("created_at")

  turno Turno @relation(fields: [turnoId], references: [id], onDelete: Cascade)

  @@index([turnoId])
  @@map("archivo")
}

model Pago {
  id                  String      @id @default(uuid())
  turnoId             String      @unique @map("turno_id")
  monto               Decimal     @db.Decimal(10, 2)
  comisionPorcentaje  Decimal     @default(10) @map("comision_porcentaje") @db.Decimal(5, 2)
  montoNeto           Decimal     @map("monto_neto") @db.Decimal(10, 2)
  estado              EstadoPago  @default(PENDIENTE)
  mpPreferenciaId     String?     @map("mp_preferencia_id")
  mpPaymentId         String?     @map("mp_payment_id")
  mpStatus            String?     @map("mp_status")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  turno Turno @relation(fields: [turnoId], references: [id], onDelete: Cascade)

  @@map("pago")
}

model ListaEspera {
  id            String           @id @default(uuid())
  profesionalId String           @map("profesional_id")
  pacienteId    String           @map("paciente_id")
  fecha         DateTime         @db.Date
  modalidad     Modalidad
  estado        EstadoListaEspera @default(ACTIVA)
  notificadoAt  DateTime?        @map("notificado_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  profesional Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)
  paciente    Paciente    @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([profesionalId, fecha, estado])
  @@index([pacienteId, estado])
  @@unique([profesionalId, pacienteId, fecha, modalidad, estado])
  @@map("lista_espera")
}

model BloqueoDisponibilidad {
  id            String    @id @default(uuid())
  profesionalId String    @map("profesional_id")
  fechaInicio   DateTime  @db.Date @map("fecha_inicio")
  fechaFin      DateTime  @db.Date @map("fecha_fin")
  horaInicio    String?   @map("hora_inicio")
  horaFin       String?   @map("hora_fin")
  motivo        String?
  createdAt     DateTime  @default(now()) @map("created_at")

  profesional Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)

  @@index([profesionalId, fechaInicio, fechaFin])
  @@map("bloqueo_disponibilidad")
}

model Resena {
  id            String    @id @default(uuid())
  turnoId       String    @unique @map("turno_id")
  profesionalId String    @map("profesional_id")
  pacienteId    String    @map("paciente_id")
  rating        Int
  comentario    String?
  respuesta     String?
  respondidaAt  DateTime? @map("respondida_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  turno       Turno       @relation(fields: [turnoId], references: [id], onDelete: Cascade)
  profesional Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)
  paciente    Paciente    @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([profesionalId])
  @@index([pacienteId])
  @@map("resena")
}

model Notificacion {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  tipo      String
  titulo    String
  cuerpo    String
  leida     Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([usuarioId, leida])
  @@index([usuarioId, createdAt])
  @@map("notificacion")
}

model RecordatorioEnviado {
  id        String   @id @default(uuid())
  turnoId   String   @map("turno_id")
  tipo      String   // "24h_paciente" | "2h_paciente" | "24h_profesional" | "2h_profesional"
  enviadoAt DateTime @default(now()) @map("enviado_at")

  @@unique([turnoId, tipo])
  @@index([enviadoAt])
  @@map("recordatorio_enviado")
}
